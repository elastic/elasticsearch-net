<?xml version="1.0" encoding="utf-8"?>
<doc>
  <member key="_types.query_dsl.SimpleQueryStringFlag#ALL"><summary><para>
Enables all optional operators.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#AND"><summary><para>
Enables the <c>+</c> AND operator.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#ESCAPE"><summary><para>
Enables <c>\</c> as an escape character.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#FUZZY"><summary><para>
Enables the <c>~N</c> operator after a word, where <c>N</c> is an integer denoting the allowed edit distance for matching.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#NEAR"><summary><para>
Enables the <c>~N</c> operator, after a phrase where <c>N</c> is the maximum number of positions allowed between matching tokens.
Synonymous to <c>SLOP</c>.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#NONE"><summary><para>
Disables all operators.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#NOT"><summary><para>
Enables the <c>-</c> NOT operator.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#OR"><summary><para>
Enables the <c>\|</c> OR operator.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#PHRASE"><summary><para>
Enables the <c>"</c> quotes operator used to search for phrases.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#PRECEDENCE"><summary><para>
Enables the <c>(</c> and <c>)</c> operators to control operator precedence.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#PREFIX"><summary><para>
Enables the <c>*</c> prefix operator.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#SLOP"><summary><para>
Enables the <c>~N</c> operator, after a phrase where <c>N</c> is maximum number of positions allowed between matching tokens.
Synonymous to <c>NEAR</c>.
</para></summary></member>
  <member key="_types.query_dsl.SimpleQueryStringFlag#WHITESPACE"><summary><para>
Enables whitespace as split characters.
</para></summary></member>
</doc>